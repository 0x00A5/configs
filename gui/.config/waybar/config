[
  {
    "layer": "top",
    "position": "top",
    "height": 32,
    "spacing": 8,

    "modules-left": [
      "custom/arch",
      "sway/window"
    ],
    "modules-right": [
      "sway/workspaces",
      "tray",
      "cpu",
      "memory",
      "battery#bat0",
      "battery#bat1",
      "clock"
    ],

    // Arch icon
    "custom/arch": {
      "format": "",
      "tooltip": false
    },

    // Focused window title
    "sway/window": {
      "max-length": 17,
      "separate-outputs": true
    },

    // Sway workspaces
    "sway/workspaces": {
      "disable-scroll": true,
      "all-outputs": false,
      "format": "{name}"
    },

    // System tray
    "tray": {
      "spacing": 10
    },

    // CPU usage with a stepped bar, matching Polybar's ramp idea
    "cpu": {
      "interval": 3,
      "format": " {icon0} {icon1} {icon2} {icon3} {icon4} {icon5} {icon6} {icon7}",
      "format-icons": ["▁", "▂", "▃", "▄", "▅", "▆", "▇", "█"]
    },

    // Memory usage
    "memory": {
      "interval": 3,
      "format": " {}%"
    },

    // First battery
    "battery#bat0": {
      "bat": "BAT0",
      "adapter": "AC",
      "interval": 5,
      "states": {
        "warning": 10
      },
      "format": "{icon} {capacity}%",
      "format-charging": "{icon}  {capacity}%",
      "format-full": "{icon} {capacity}%",
      "format-warning": "{icon} {capacity}%",
      "format-icons": [
        "",
        "",
        "",
        "",
        ""
      ]
    },

    // Second battery
    "battery#bat1": {
      "bat": "BAT1",
      "adapter": "AC",
      "interval": 5,
      "states": {
        "warning": 10
      },
      "format": "{icon} {capacity}%",
      "format-charging": "{icon}  {capacity}%",
      "format-full": "{icon} {capacity}%",
      "format-warning": "{icon} {capacity}%",
      "format-icons": [
        "",
        "",
        "",
        "",
        ""
      ]
    },

    // Date and time
    "clock": {
      "interval": 1,
      "format": " {:%Y-%m-%d %H:%M}",
      "format-alt": "{:%H:%M}"
    }
  }
]
