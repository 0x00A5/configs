[
  {
    "layer": "top",
    "position": "top",
    "height": 32,
    "spacing": 8,

    "modules-left": [
	  "sway/workspaces",
	  "wlr/taskbar"
    ],
    "modules-right": [
      "tray",
      "network",
      "pulseaudio",
      "battery#bat0",
      "battery#bat1",
      "battery#bat3",
      "clock"
    ],

	// Taskbar
	"wlr/taskbar": {
		"format": "{icon}",
		"icon-size": 14,
		"icon-theme": "Numix-Circle",
		"tooltip-format": "{title}",
		"on-click": "activate",
		"on-click-middle": "close",
		"ignore-list": [
			"foot"
		]
	},

    // Sway workspaces
    "sway/workspaces": {
      "disable-scroll": true,
      "all-outputs": false,
      "format": "{name}"
    },

    // System tray
    "tray": {
      "spacing": 10
    },

    // Wi-Fi status
    "network": {
      "interval": 5,
      "format-wifi": "  {essid}",
      "format-disconnected": "󰖪",
	  "max-length": 18,
      "tooltip-format-wifi": "{ifname} {ipaddr}/{cidr}\n{essid} {signalStrength}%",
      "tooltip-format-disconnected": "Wi-Fi disconnected"
    },

    // Audio volume
    "pulseaudio": {
      "format": " {volume}%",
      "format-muted": "󰖁",
      "scroll-step": 5,
      "tooltip": false,
	  "on-click": "pavucontrol"
    },

    // CPU usage with a stepped bar, matching Polybar's ramp idea
    "cpu": {
      "interval": 3,
      "format": " {icon0} {icon1} {icon2} {icon3} {icon4} {icon5} {icon6} {icon7}",
      "format-icons": ["▁", "▂", "▃", "▄", "▅", "▆", "▇", "█"]
    },

    // Memory usage
    "memory": {
      "interval": 3,
      "format": " {}%"
    },

    // First battery
    "battery#bat0": {
      "bat": "BAT0",
      "adapter": "AC",
      "interval": 5,
      "states": {
        "warning": 10
      },
      "format": "{icon} {capacity}%",
      "format-charging": "{icon}  {capacity}%",
      "format-full": "{icon} {capacity}%",
      "format-warning": "{icon} {capacity}%",
      "format-icons": [
        "",
        "",
        "",
        "",
        ""
      ]
    },

    // Second battery
    "battery#bat1": {
      "bat": "BAT1",
      "adapter": "AC",
      "interval": 5,
      "states": {
        "warning": 10
      },
      "format": "{icon} {capacity}%",
      "format-charging": "{icon}  {capacity}%",
      "format-full": "{icon} {capacity}%",
      "format-warning": "{icon} {capacity}%",
      "format-icons": [
        "",
        "",
        "",
        "",
        ""
      ]
    },

    // First battery on Asahi
    "battery#bat3": {
      "bat": "macsmc-battery",
      "adapter": "AC",
      "interval": 5,
      "states": {
        "warning": 10
      },
      "format": "{icon} {capacity}%",
      "format-charging": "{icon}  {capacity}%",
      "format-full": "{icon} {capacity}%",
      "format-warning": "{icon} {capacity}%",
      "format-icons": [
        "",
        "",
        "",
        "",
        ""
      ]
    },

    // Date and time
    "clock": {
      "interval": 1,
      "tooltip": false,
      "format": " {:%Y-%m-%d %H:%M}",
      "format-alt": "{:%H:%M}"
    }
  }
]
