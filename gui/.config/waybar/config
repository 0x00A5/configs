[
  {
    "layer": "top",
    "position": "top",
    "height": 32,
    "spacing": 8,

    "modules-left": [
      "custom/power",
	  "wlr/taskbar"
    ],
    "modules-right": [
      "sway/workspaces",
      "tray",
      "pulseaudio",
      "battery#bat0",
      "battery#bat1",
      "battery#bat3",
      "clock"
    ],

    // Power menu
	"custom/power": {
		"format": "вЏ»",
		"on-click": "wlogout"
	},

	// Taskbar
	"wlr/taskbar": {
      "format": "{icon}",
      "icon-size": 14,
      "icon-theme": "Numix-Circle",
      "tooltip-format": "{title}",
      "on-click": "activate",
      "on-click-middle": "close",
	  "ignore-list": []
	},

    // Sway workspaces
    "sway/workspaces": {
      "disable-scroll": true,
      "all-outputs": false,
      "format": "{name}"
    },

    // System tray
    "tray": {
      "spacing": 10
    },

    // Audio volume
    "pulseaudio": {
      "format": "пЂЁ {volume}%",
      "format-muted": "у°–Ѓ",
      "scroll-step": 5,
      "tooltip": false,
	  "on-click": "pavucontrol"
    },

    // CPU usage with a stepped bar, matching Polybar's ramp idea
    "cpu": {
      "interval": 3,
      "format": "п‹› {icon0} {icon1} {icon2} {icon3} {icon4} {icon5} {icon6} {icon7}",
      "format-icons": ["в–Ѓ", "в–‚", "в–ѓ", "в–„", "в–…", "в–†", "в–‡", "в–€"]
    },

    // Memory usage
    "memory": {
      "interval": 3,
      "format": "ої… {}%"
    },

    // First battery
    "battery#bat0": {
      "bat": "BAT0",
      "adapter": "AC",
      "interval": 5,
      "states": {
        "warning": 10
      },
      "format": "{icon} {capacity}%",
      "format-charging": "{icon} пѓ§ {capacity}%",
      "format-full": "{icon} {capacity}%",
      "format-warning": "{icon} {capacity}%",
      "format-icons": [
        "п‰„",
        "п‰ѓ",
        "п‰‚",
        "п‰Ѓ",
        "п‰Ђ"
      ]
    },

    // Second battery
    "battery#bat1": {
      "bat": "BAT1",
      "adapter": "AC",
      "interval": 5,
      "states": {
        "warning": 10
      },
      "format": "{icon} {capacity}%",
      "format-charging": "{icon} пѓ§ {capacity}%",
      "format-full": "{icon} {capacity}%",
      "format-warning": "{icon} {capacity}%",
      "format-icons": [
        "п‰„",
        "п‰ѓ",
        "п‰‚",
        "п‰Ѓ",
        "п‰Ђ"
      ]
    },

    // First battery on Asahi
    "battery#bat3": {
      "bat": "macsmc-battery",
      "adapter": "AC",
      "interval": 5,
      "states": {
        "warning": 10
      },
      "format": "{icon} {capacity}%",
      "format-charging": "{icon} пѓ§ {capacity}%",
      "format-full": "{icon} {capacity}%",
      "format-warning": "{icon} {capacity}%",
      "format-icons": [
        "п‰„",
        "п‰ѓ",
        "п‰‚",
        "п‰Ѓ",
        "п‰Ђ"
      ]
    },

    // Date and time
    "clock": {
      "interval": 1,
      "tooltip": false,
      "format": "пЃі {:%Y-%m-%d %H:%M}",
      "format-alt": "{:%H:%M}"
    }
  }
]
